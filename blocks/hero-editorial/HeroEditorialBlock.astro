---
import type { HydratedHeroEditorialBlock } from '@/lib/content'
import OptimizedImage from '@/components/OptimizedImage.astro'

type Props = Omit<HydratedHeroEditorialBlock, '_uid' | 'type'>

const { kicker, title, lead, photoCredit, image, link } = Astro.props
const newTab = link?.target === 'new-tab'
---

<section class="hero-editorial" style="display:grid; grid-template-columns:1fr 1fr; align-items:stretch;">
  <div style="background:var(--color-primary); color:var(--color-primary-contrast); padding:48px 40px;">
    {
      kicker && (
        <span
          data-field="kicker"
          style="font-weight:700; font-size:13px; letter-spacing:0.3em; text-transform:uppercase; display:block; margin-bottom:20px;"
        >
          {kicker}
        </span>
      )
    }
    {
      link?.url ? (
        <a
          href={link.url}
          target={newTab ? '_blank' : undefined}
          rel={newTab ? 'noopener noreferrer' : undefined}
          class="disp"
          style="display:block; font-size:clamp(40px,4.5vw,76px); margin:0 0 28px; color:var(--color-primary-contrast);"
          data-field="title"
        >
          {title}
        </a>
      ) : (
        <h2 class="disp" data-field="title" style="font-size:clamp(40px,4.5vw,76px); margin:0 0 28px;">
          {title}
        </h2>
      )
    }
    {
      lead && (
        <p
          data-field="lead"
          style="font-weight:700; font-size:14px; text-transform:uppercase; line-height:1.25; max-width:420px; margin:0;"
        >
          {lead}
          {photoCredit && (
            <span data-field="photoCredit" style="display:block; margin-top:8px; opacity:.55;">
              {photoCredit}
            </span>
          )}
        </p>
      )
    }
  </div>
  <div style="overflow:hidden;">
    {
      image ? (
        <OptimizedImage
          data-media-field="image"
          class="gs"
          image={image}
          eager
          sizes="(min-width: 48rem) 50vw, 100vw"
          style="width:100%; height:100%; object-fit:cover; display:block;"
        />
      ) : (
        <div style="width:100%; height:100%; min-height:320px; background:var(--color-surface-alt);" aria-hidden="true" />
      )
    }
  </div>
</section>

<style>
  @media (max-width: 48rem) {
    .hero-editorial {
      grid-template-columns: 1fr !important;
    }
  }
</style>
