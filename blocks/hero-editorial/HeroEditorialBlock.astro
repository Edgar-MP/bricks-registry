---
import type { HydratedHeroEditorialBlock } from '@/lib/content'
import OptimizedImage from '@/components/OptimizedImage.astro'

type Props = Omit<HydratedHeroEditorialBlock, '_uid' | 'type'>

const { kicker, title, lead, photoCredit, image, link } = Astro.props
const newTab = link?.target === 'new-tab'
const Wrapper = link?.url ? 'a' : 'div'
---

<section class="flex flex-col" data-reveal>
  <Wrapper
    href={link?.url}
    target={newTab ? '_blank' : undefined}
    rel={newTab ? 'noopener noreferrer' : undefined}
    class="block w-full bg-primary p-6 text-primary-contrast md:p-12"
  >
    <div class="max-w-5xl">
      {
        kicker && (
          // Mismas propiedades que `typo-overline` pero SIN su color fijo
          // (text-muted pelearía con text-primary-contrast/70 aquí: misma
          // especificidad, orden de generación no garantizado — ver nota en
          // ui/Card.astro sobre este mismo problema).
          <span
            data-field="kicker"
            class="mb-4 block text-sm font-semibold uppercase tracking-[0.1em] text-primary-contrast/70"
          >
            {kicker}
          </span>
        )
      }
      <h2 data-field="title" class="typo-hero text-balance">{title}</h2>
      {
        lead && (
          <p data-field="lead" class="typo-body-lg mt-6 max-w-xl font-bold uppercase leading-tight">
            {lead}
            {photoCredit && (
              <span data-field="photoCredit" class="mt-2 block font-normal normal-case opacity-70">
                {photoCredit}
              </span>
            )}
          </p>
        )
      }
    </div>
  </Wrapper>
  {
    image && (
      <div class="aspect-video w-full overflow-hidden">
        <OptimizedImage
          data-media-field="image"
          class="h-full w-full object-cover grayscale transition-all duration-700 hover:grayscale-0"
          image={image}
          eager
          sizes="100vw"
        />
      </div>
    )
  }
</section>
