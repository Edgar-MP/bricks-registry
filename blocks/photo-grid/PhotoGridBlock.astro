---
import type { HydratedPhotoGridBlock } from '@/lib/content'
import OptimizedImage from '@/components/OptimizedImage.astro'

type Props = Omit<HydratedPhotoGridBlock, '_uid' | 'type'>

const { images, columns } = Astro.props
const rendered = images.filter((item) => item.image)

const cols = { '2': 'sm:grid-cols-2', '3': 'sm:grid-cols-3' }[columns]
---

{
  rendered.length > 0 && (
    <section class="mx-auto max-w-content px-6 py-section" data-reveal>
      <ul class:list={['grid grid-cols-1 gap-8', cols]}>
        {rendered.map((item, index) => (
          <li class="border-2 border-border">
            <OptimizedImage
              data-media-field="images"
              class="aspect-[4/3] w-full object-cover"
              image={item.image!}
              alt={item.caption ?? item.image!.alt ?? ''}
              sizes={{ '2': '50vw', '3': '33vw' }[columns]}
            />
            <div class="flex items-start justify-between gap-3 border-t-2 border-border p-3">
              <div class="flex items-start gap-3">
                <span class="typo-overline shrink-0 border-2 border-border bg-primary px-2 py-0.5 text-primary-contrast">
                  {String(index + 1).padStart(2, '0')}
                </span>
                {item.caption && <p class="typo-body">{item.caption}</p>}
              </div>
              {item.credit && <p class="typo-overline shrink-0">{item.credit}</p>}
            </div>
          </li>
        ))}
      </ul>
    </section>
  )
}
