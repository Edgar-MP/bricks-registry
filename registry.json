{
  "$schema": "./registry.schema.json",
  "blocks": {
    "hero": {
      "kind": "block",
      "version": "1.0.0",
      "description": "Cabecera de página: título, subtítulo, imagen de fondo y CTA.",
      "category": "cabeceras",
      "files": [
        { "from": "blocks/hero/schema.ts", "to": "packages/schema/src/blocks/hero.ts" },
        {
          "from": "blocks/hero/HeroBlock.astro",
          "to": "apps/front/src/components/blocks/HeroBlock.astro"
        }
      ]
    },
    "hero-editorial": {
      "kind": "block",
      "version": "1.0.0",
      "description": "Hero de portada editorial: caja de color a todo ancho + imagen destacada con efecto B/N a color.",
      "category": "cabeceras",
      "files": [
        {
          "from": "blocks/hero-editorial/schema.ts",
          "to": "packages/schema/src/blocks/hero-editorial.ts"
        },
        {
          "from": "blocks/hero-editorial/HeroEditorialBlock.astro",
          "to": "apps/front/src/components/blocks/HeroEditorialBlock.astro"
        }
      ]
    },
    "quote": {
      "kind": "block",
      "version": "1.0.0",
      "description": "Cita o pull-quote para separar tramos de texto, variantes plain/boxed.",
      "category": "editorial",
      "files": [
        { "from": "blocks/quote/schema.ts", "to": "packages/schema/src/blocks/quote.ts" },
        {
          "from": "blocks/quote/QuoteBlock.astro",
          "to": "apps/front/src/components/blocks/QuoteBlock.astro"
        }
      ]
    },
    "photo-grid": {
      "kind": "block",
      "version": "1.0.0",
      "description": "Galería editorial brutalista con pie de foto y crédito siempre visibles, pensada para foto-ensayos.",
      "category": "editorial",
      "files": [
        {
          "from": "blocks/photo-grid/schema.ts",
          "to": "packages/schema/src/blocks/photo-grid.ts"
        },
        {
          "from": "blocks/photo-grid/PhotoGridBlock.astro",
          "to": "apps/front/src/components/blocks/PhotoGridBlock.astro"
        }
      ]
    },
    "titular": {
      "kind": "block",
      "version": "1.0.0",
      "description": "Titular de sección brutalista para romper tramos de texto, variantes plain/inverted.",
      "category": "editorial",
      "files": [
        { "from": "blocks/titular/schema.ts", "to": "packages/schema/src/blocks/titular.ts" },
        {
          "from": "blocks/titular/TitularBlock.astro",
          "to": "apps/front/src/components/blocks/TitularBlock.astro"
        }
      ]
    },
    "tabs": {
      "kind": "block",
      "version": "1.0.0",
      "description": "Pestañas con contenido richtext por pestaña, variantes underline/pill.",
      "category": "interactivos",
      "files": [
        { "from": "blocks/tabs/schema.ts", "to": "packages/schema/src/blocks/tabs.ts" },
        {
          "from": "blocks/tabs/TabsBlock.astro",
          "to": "apps/front/src/components/blocks/TabsBlock.astro"
        }
      ]
    },
    "restaurante": {
      "kind": "pack",
      "version": "1.0.0",
      "description": "Vertical de restaurante: cartas, platos y bebidas.",
      "category": "verticales",
      "files": [
        { "from": "packs/restaurante/types/carta.ts", "to": "packages/schema/src/types/carta.ts" },
        { "from": "packs/restaurante/types/plato.ts", "to": "packages/schema/src/types/plato.ts" },
        { "from": "packs/restaurante/types/bebida.ts", "to": "packages/schema/src/types/bebida.ts" },
        {
          "from": "packs/restaurante/blocks/carta-embed.ts",
          "to": "packages/schema/src/blocks/carta-embed.ts"
        },
        {
          "from": "packs/restaurante/blocks/CartaEmbedBlock.astro",
          "to": "apps/front/src/components/blocks/CartaEmbedBlock.astro"
        },
        {
          "from": "packs/restaurante/blocks/menu-platos.ts",
          "to": "packages/schema/src/blocks/menu-platos.ts"
        },
        {
          "from": "packs/restaurante/blocks/MenuPlatosBlock.astro",
          "to": "apps/front/src/components/blocks/MenuPlatosBlock.astro"
        },
        {
          "from": "packs/restaurante/blocks/menu-bebidas.ts",
          "to": "packages/schema/src/blocks/menu-bebidas.ts"
        },
        {
          "from": "packs/restaurante/blocks/MenuBebidasBlock.astro",
          "to": "apps/front/src/components/blocks/MenuBebidasBlock.astro"
        }
      ],
      "contentTypes": [
        {
          "type": "carta",
          "schemaModule": "carta",
          "schemaExport": "cartaSchema",
          "kind": "collection",
          "routing": "/carta/:slug",
          "labelField": "title"
        },
        {
          "type": "plato",
          "schemaModule": "plato",
          "schemaExport": "platoSchema",
          "kind": "collection",
          "routing": null,
          "labelField": "nombre"
        },
        {
          "type": "bebida",
          "schemaModule": "bebida",
          "schemaExport": "bebidaSchema",
          "kind": "collection",
          "routing": null,
          "labelField": "nombre"
        }
      ],
      "blocks": [
        { "type": "carta-embed", "description": "Incrusta el resumen de una carta." },
        { "type": "menu-platos", "description": "Listado de platos por secciones." },
        { "type": "menu-bebidas", "description": "Listado de bebidas por secciones." }
      ]
    },
    "reportajes": {
      "kind": "pack",
      "version": "1.0.0",
      "description": "Foto-ensayos/reportajes con routing propia, separados de las noticias.",
      "category": "verticales",
      "files": [
        {
          "from": "packs/reportajes/types/reportaje.ts",
          "to": "packages/schema/src/types/reportaje.ts"
        }
      ],
      "contentTypes": [
        {
          "type": "reportaje",
          "schemaModule": "reportaje",
          "schemaExport": "reportajeSchema",
          "kind": "collection",
          "routing": "/reportajes/:slug",
          "labelField": "title"
        }
      ],
      "blocks": []
    },
    "personal": {
      "kind": "pack",
      "version": "1.1.0",
      "description": "Equipo/personal de una empresa: ficha de persona y bloque de listado.",
      "category": "general",
      "files": [
        {
          "from": "packs/personal/types/miembro.ts",
          "to": "packages/schema/src/types/miembro.ts"
        },
        {
          "from": "packs/personal/blocks/equipo.ts",
          "to": "packages/schema/src/blocks/equipo.ts"
        },
        {
          "from": "packs/personal/blocks/EquipoBlock.astro",
          "to": "apps/front/src/components/blocks/EquipoBlock.astro"
        },
        {
          "from": "packs/personal/admin/MiembroCardPreview.tsx",
          "to": "apps/admin/src/components/packages/personal/MiembroCardPreview.tsx"
        }
      ],
      "contentTypes": [
        {
          "type": "miembro",
          "schemaModule": "miembro",
          "schemaExport": "miembroSchema",
          "kind": "collection",
          "routing": null,
          "labelField": "nombre",
          "adminPreview": {
            "component": "MiembroCardPreview",
            "to": "apps/admin/src/components/packages/personal/MiembroCardPreview.tsx"
          }
        }
      ],
      "blocks": [
        { "type": "equipo", "description": "Lista el personal de la empresa (equipo)." }
      ]
    }
  }
}
