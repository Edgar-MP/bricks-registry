{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "bricks-registry catalog",
  "type": "object",
  "required": ["blocks"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "blocks": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["version", "description", "files"],
        "additionalProperties": false,
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["block", "pack"],
            "default": "block",
            "description": "'block' = bloque suelto. 'pack' = paquete de funcionalidad (tarea 90): N tipos de contenido + M bloques, ver `contentTypes`/`blocks`."
          },
          "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
          "description": { "type": "string" },
          "category": {
            "type": "string",
            "description": "Agrupación para navegación en el marketplace/web de docs."
          },
          "files": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["from", "to"],
              "additionalProperties": false,
              "properties": {
                "from": { "type": "string", "description": "Ruta relativa dentro de este repo." },
                "to": { "type": "string", "description": "Ruta relativa dentro del proyecto destino." }
              }
            }
          },
          "contentTypes": {
            "type": "array",
            "description": "Solo para kind === 'pack': tipos de contenido que registra, ver packages/cli/docs/PACKS.md.",
            "items": {
              "type": "object",
              "required": ["type", "schemaModule", "schemaExport", "kind", "routing", "labelField"],
              "additionalProperties": false,
              "properties": {
                "type": { "type": "string" },
                "schemaModule": {
                  "type": "string",
                  "description": "Nombre de fichero sin extensión, dentro de packages/schema/src/types/."
                },
                "schemaExport": { "type": "string" },
                "kind": { "type": "string", "enum": ["collection", "single"] },
                "routing": { "type": ["string", "null"] },
                "labelField": { "type": "string" }
              }
            }
          },
          "blocks": {
            "type": "array",
            "description": "Solo para kind === 'pack': bloques que registra, ver packages/cli/docs/PACKS.md.",
            "items": {
              "type": "object",
              "required": ["type", "description"],
              "additionalProperties": false,
              "properties": {
                "type": { "type": "string" },
                "description": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
