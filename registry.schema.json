{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "bricks-registry catalog",
  "type": "object",
  "required": ["blocks"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "blocks": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["version", "description", "files"],
        "additionalProperties": false,
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["block", "pack"],
            "default": "block",
            "description": "'block' = bloque suelto. 'pack' reservado para paquetes de funcionalidad (tarea 90, no implementado aún)."
          },
          "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
          "description": { "type": "string" },
          "category": {
            "type": "string",
            "description": "Agrupación para navegación en el marketplace/web de docs."
          },
          "files": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["from", "to"],
              "additionalProperties": false,
              "properties": {
                "from": { "type": "string", "description": "Ruta relativa dentro de este repo." },
                "to": { "type": "string", "description": "Ruta relativa dentro del proyecto destino." }
              }
            }
          }
        }
      }
    }
  }
}
